#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory (repo root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse arguments
BRANCH=""
FROM_BRANCH=""
while [[ $# -gt 0 ]]; do
  case $1 in
    --branch)
      BRANCH="$2"
      shift 2
      ;;
    --from)
      FROM_BRANCH="$2"
      shift 2
      ;;
    *)
      echo -e "${RED}Unknown argument: $1${NC}"
      echo "Usage: ./spawn-agent --branch <branch-name> [--from <source-branch>]"
      exit 1
      ;;
  esac
done

if [ -z "$BRANCH" ]; then
  echo -e "${RED}Error: --branch argument is required${NC}"
  echo "Usage: ./spawn-agent --branch <branch-name> [--from <source-branch>]"
  exit 1
fi

echo -e "${BLUE}🚀 Spawning new Pi agent for branch: ${BRANCH}${NC}"
echo ""

# Sanitize branch name for directory (replace slashes and special chars with dashes,
# strip leading "sprint/" prefix so sprint/64123-fix-sorting → 64123-fix-sorting)
BRANCH_STRIPPED="${BRANCH#sprint/}"
WORKTREE_NAME=$(echo "$BRANCH_STRIPPED" | sed 's/[^a-zA-Z0-9_-]/-/g')

# Worktree path (inside repo at .worktrees/)
WORKTREE_PATH="${SCRIPT_DIR}/.worktrees/${WORKTREE_NAME}"

# Derive names from worktree name
DB_NAME="$(basename "$SCRIPT_DIR")_dev_${WORKTREE_NAME//-/_}"
BUCKET_NAME="uploads-${WORKTREE_NAME}"

# Port: base 4001 plus number of existing worktrees
WORKTREE_COUNT=$(git worktree list | wc -l | tr -d ' ')
PORT=$((4001 + WORKTREE_COUNT))

echo -e "${YELLOW}Configuration:${NC}"
echo "  Branch:   ${BRANCH}"
echo "  Worktree: ${WORKTREE_PATH}"
echo "  Port:     ${PORT}"
echo "  Database: ${DB_NAME}"
echo "  Bucket:   ${BUCKET_NAME}"
echo ""

# Check if worktree already exists
if [ -d "$WORKTREE_PATH" ]; then
  echo -e "${RED}Error: Worktree directory already exists: ${WORKTREE_PATH}${NC}"
  exit 1
fi

# Ensure .worktrees/ is git-ignored
GITIGNORE="${SCRIPT_DIR}/.gitignore"
if ! grep -qxF '.worktrees/' "$GITIGNORE" 2>/dev/null; then
  echo "" >> "$GITIGNORE"
  echo "# Agent worktrees" >> "$GITIGNORE"
  echo ".worktrees/" >> "$GITIGNORE"
  echo -e "${GREEN}✓ Added .worktrees/ to .gitignore${NC}"
fi

# Create git worktree
echo -e "${GREEN}📂 Creating git worktree...${NC}"
if git rev-parse --verify "$BRANCH" >/dev/null 2>&1; then
  # Branch exists locally
  git worktree add "$WORKTREE_PATH" "$BRANCH"
elif git ls-remote --heads origin "$BRANCH" | grep -q "$BRANCH"; then
  # Branch exists on remote
  git worktree add "$WORKTREE_PATH" "$BRANCH"
else
  # Branch doesn't exist, create it
  if [ -n "$FROM_BRANCH" ]; then
    echo -e "${YELLOW}Branch '$BRANCH' doesn't exist. Creating from '$FROM_BRANCH'...${NC}"
    git worktree add -b "$BRANCH" "$WORKTREE_PATH" "$FROM_BRANCH"
  else
    echo -e "${YELLOW}Branch '$BRANCH' doesn't exist. Creating from current branch...${NC}"
    git worktree add -b "$BRANCH" "$WORKTREE_PATH"
  fi
fi

# Copy and merge .env files
echo -e "${GREEN}🔧 Setting up environment configuration...${NC}"
cd "$WORKTREE_PATH"

# Start with base .env.local
if [ -f "${SCRIPT_DIR}/.env.local" ]; then
  cp "${SCRIPT_DIR}/.env.local" .env.local
else
  echo -e "${RED}Warning: .env.local not found in main repository${NC}"
  touch .env.local
fi

# Merge .env.bedrock-claude if it exists
if [ -f "${SCRIPT_DIR}/.env.bedrock-claude" ]; then
  echo "" >> .env.local
  echo "# Bedrock Claude Configuration" >> .env.local
  cat "${SCRIPT_DIR}/.env.bedrock-claude" >> .env.local
fi

# Append worktree-specific overrides
echo "" >> .env.local
echo "# Worktree-specific configuration" >> .env.local
echo "export PHX_PORT=${PORT}" >> .env.local
echo "export DATABASE_NAME=${DB_NAME}" >> .env.local
echo "export S3_BUCKET_NAME=${BUCKET_NAME}" >> .env.local

echo -e "${GREEN}✓ Environment configured${NC}"
echo ""

# Source the environment
source .env.local

# Install dependencies
echo -e "${GREEN}📦 Installing dependencies...${NC}"
mix deps.get

# Setup database
echo -e "${GREEN}🗄️  Setting up database...${NC}"
if mix ecto.create; then
  echo -e "${GREEN}✓ Database created${NC}"
else
  echo -e "${YELLOW}Database might already exist, continuing...${NC}"
fi

mix ecto.migrate
echo -e "${GREEN}✓ Database migrated${NC}"
echo ""

# Setup S3 bucket
echo -e "${GREEN}🪣 Setting up S3 bucket...${NC}"
mix run etc/ensure_s3_bucket.exs
echo ""

# Create quick start script
echo -e "${GREEN}📝 Creating start script...${NC}"
cat > start.sh << 'EOF'
#!/bin/bash
set -e

# Load environment
source .env.local

# Ensure database is migrated
mix ecto.migrate

# Ensure S3 bucket exists
mix run etc/ensure_s3_bucket.exs

# Start server
mix phx.server
EOF

chmod +x start.sh
echo -e "${GREEN}✓ Created start.sh${NC}"
echo ""

# Summary
echo -e "${BLUE}════════════════════════════════════════════════${NC}"
echo -e "${GREEN}✨ Worktree setup complete!${NC}"
echo -e "${BLUE}════════════════════════════════════════════════${NC}"
echo ""
echo -e "${YELLOW}Worktree location:${NC} ${WORKTREE_PATH}"
echo -e "${YELLOW}Server will run on:${NC} http://localhost:${PORT}"
echo -e "${YELLOW}Database:${NC} ${DB_NAME}"
echo -e "${YELLOW}S3 Bucket:${NC} ${BUCKET_NAME}"
echo ""
echo -e "${YELLOW}To start the server later:${NC}"
echo "  cd ${WORKTREE_PATH} && ./start.sh"
echo ""
echo -e "${YELLOW}To remove this worktree when done:${NC}"
echo "  ./remove-agent --worktree ${WORKTREE_PATH} --remove-db --remove-bucket"
echo ""

# Launch Pi
echo -e "${GREEN}🤖 Launching Pi...${NC}"
echo ""
cd "$WORKTREE_PATH"

if [ -z "$PI_CMD" ]; then
  echo -e "${RED}Error: PI_CMD is not set in .env.local${NC}"
  echo "Add a line like:"
  echo "  export PI_CMD=\"pi\""
  echo "or for Bedrock:"
  echo "  export PI_CMD=\"AWS_PROFILE=my-profile pi --provider amazon-bedrock --model <arn>\""
  exit 1
fi

eval "$PI_CMD"
