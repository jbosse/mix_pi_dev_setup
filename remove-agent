#!/bin/bash

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory (repo root)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse arguments
WORKTREE_PATH=""
REMOVE_DB=false
REMOVE_BUCKET=false
FORCE=false

while [[ $# -gt 0 ]]; do
  case $1 in
    --worktree)
      WORKTREE_PATH="$2"
      shift 2
      ;;
    --remove-db)
      REMOVE_DB=true
      shift
      ;;
    --remove-bucket)
      REMOVE_BUCKET=true
      shift
      ;;
    --force)
      FORCE=true
      shift
      ;;
    *)
      echo -e "${RED}Unknown argument: $1${NC}"
      echo "Usage: ./remove-agent --worktree <path> [--remove-db] [--remove-bucket] [--force]"
      exit 1
      ;;
  esac
done

if [ -z "$WORKTREE_PATH" ]; then
  echo -e "${RED}Error: --worktree argument is required${NC}"
  echo "Usage: ./remove-agent --worktree <path> [--remove-db] [--remove-bucket] [--force]"
  echo ""
  echo "Examples:"
  echo "  ./remove-agent --worktree .worktrees/64123-fix-sorting"
  echo "  ./remove-agent --worktree .worktrees/64123-fix-sorting --remove-db --remove-bucket"
  echo ""
  exit 1
fi

# Resolve to absolute path
WORKTREE_PATH="$(cd "$(dirname "$WORKTREE_PATH")" 2>/dev/null && pwd)/$(basename "$WORKTREE_PATH")" || true

# Check if worktree exists
if [ ! -d "$WORKTREE_PATH" ]; then
  echo -e "${RED}Error: Worktree directory not found: ${WORKTREE_PATH}${NC}"
  exit 1
fi

# Get database, bucket, and port names from .env.local
DB_NAME=""
BUCKET_NAME=""
PORT=""

if [ -f "${WORKTREE_PATH}/.env.local" ]; then
  DB_NAME=$(grep "^export DATABASE_NAME=" "${WORKTREE_PATH}/.env.local" 2>/dev/null | cut -d'=' -f2)
  BUCKET_NAME=$(grep "^export S3_BUCKET_NAME=" "${WORKTREE_PATH}/.env.local" 2>/dev/null | cut -d'=' -f2)
  PORT=$(grep "^export PHX_PORT=" "${WORKTREE_PATH}/.env.local" 2>/dev/null | cut -d'=' -f2)
fi

# Derive DB container name from repo directory name
DB_CONTAINER="$(basename "$SCRIPT_DIR")-db-1"

WORKTREE_NAME=$(basename "$WORKTREE_PATH")

echo -e "${BLUE}🗑️  Removing Pi Agent Worktree${NC}"
echo -e "${BLUE}═══════════════════════════════════════════${NC}"
echo ""
echo -e "${YELLOW}Worktree:${NC}  ${WORKTREE_NAME}"
echo -e "${YELLOW}Path:${NC}      ${WORKTREE_PATH}"
[ -n "$PORT" ]        && echo -e "${YELLOW}Port:${NC}      ${PORT}"
[ -n "$DB_NAME" ]     && echo -e "${YELLOW}Database:${NC}  ${DB_NAME}"
[ -n "$BUCKET_NAME" ] && echo -e "${YELLOW}Bucket:${NC}    ${BUCKET_NAME}"
echo ""

# Check if server is running
if [ -n "$PORT" ] && lsof -i ":${PORT}" >/dev/null 2>&1; then
  echo -e "${RED}⚠️  Warning: Server is currently running on port ${PORT}${NC}"
  echo "Please stop the server (Ctrl+C) before removing the worktree."
  echo ""
  if [ "$FORCE" = false ]; then
    exit 1
  fi
fi

# Confirm removal
if [ "$FORCE" = false ]; then
  echo -e "${YELLOW}This will:${NC}"
  echo "  - Remove the worktree directory"
  [ "$REMOVE_DB" = true ]     && [ -n "$DB_NAME" ]     && echo "  - Drop database: ${DB_NAME}"
  [ "$REMOVE_BUCKET" = true ] && [ -n "$BUCKET_NAME" ] && echo "  - Remove S3 bucket: ${BUCKET_NAME}"
  echo ""
  read -p "Are you sure? (y/N) " -n 1 -r
  echo ""
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo -e "${YELLOW}Cancelled${NC}"
    exit 0
  fi
fi

# Remove database
if [ "$REMOVE_DB" = true ] && [ -n "$DB_NAME" ]; then
  echo -e "${GREEN}Dropping database ${DB_NAME}...${NC}"
  if docker exec "$DB_CONTAINER" psql -U postgres -c "DROP DATABASE IF EXISTS ${DB_NAME};" 2>/dev/null; then
    echo -e "${GREEN}✓ Database dropped${NC}"
  else
    echo -e "${YELLOW}⚠ Could not drop database (container may not be running)${NC}"
  fi
fi

# Remove S3 bucket
if [ "$REMOVE_BUCKET" = true ] && [ -n "$BUCKET_NAME" ]; then
  echo -e "${GREEN}Removing S3 bucket ${BUCKET_NAME}...${NC}"
  if aws --endpoint-url=http://localhost:4567 s3 rb "s3://${BUCKET_NAME}" --force 2>/dev/null; then
    echo -e "${GREEN}✓ S3 bucket removed${NC}"
  else
    echo -e "${YELLOW}⚠ Could not remove bucket (may not exist)${NC}"
  fi
fi

# Remove worktree
echo -e "${GREEN}Removing worktree...${NC}"
if git worktree remove "$WORKTREE_PATH"; then
  echo -e "${GREEN}✓ Worktree removed${NC}"
else
  echo -e "${RED}✗ Failed to remove worktree (try --force or remove manually)${NC}"
  echo "  git worktree remove --force ${WORKTREE_PATH}"
  exit 1
fi

echo ""
echo -e "${GREEN}✨ Cleanup complete!${NC}"
